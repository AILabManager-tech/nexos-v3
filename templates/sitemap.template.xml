<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  <!--
    NEXOS v3.0 — Sitemap Template

    Instructions pour seo-asset-generator :
    1. Remplacer {{BASE_URL}} par le domaine du brief (ex: https://example.com)
    2. Dupliquer le bloc <url> pour chaque page × locale
    3. Ajuster les hreflang selon les locales du brief
    4. x-default = locale principale du brief (défaut: fr)
    5. Priorité: accueil=1.0, services/about=0.8, legal=0.3

    NOTE: Ce fichier est statique (public/sitemap.xml).
    Ne PAS utiliser l'API metadata Next.js si le projet a un segment [locale]
    dynamique (conflit de routing).
  -->

  <!-- === PAGE: Accueil === -->
  <url>
    <loc>{{BASE_URL}}/fr</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
    <xhtml:link rel="alternate" hreflang="fr" href="{{BASE_URL}}/fr"/>
    <xhtml:link rel="alternate" hreflang="en" href="{{BASE_URL}}/en"/>
    <!-- {{ADDITIONAL_HREFLANG}} -->
    <xhtml:link rel="alternate" hreflang="x-default" href="{{BASE_URL}}/{{PRIMARY_LOCALE}}"/>
  </url>
  <url>
    <loc>{{BASE_URL}}/en</loc>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
    <xhtml:link rel="alternate" hreflang="fr" href="{{BASE_URL}}/fr"/>
    <xhtml:link rel="alternate" hreflang="en" href="{{BASE_URL}}/en"/>
    <!-- {{ADDITIONAL_HREFLANG}} -->
    <xhtml:link rel="alternate" hreflang="x-default" href="{{BASE_URL}}/{{PRIMARY_LOCALE}}"/>
  </url>

  <!-- === PAGES ADDITIONNELLES ===
    Dupliquer le bloc ci-dessus pour chaque page du scaffold-plan.json.
    Exemples de pages courantes :
    - /services → priority 0.8
    - /a-propos → priority 0.7
    - /contact → priority 0.7
    - /blogue → priority 0.8
    - /politique-confidentialite → priority 0.3
    - /mentions-legales → priority 0.3
  -->
</urlset>
